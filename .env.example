# Copy to .env and fill in.
PORT=3007
HOST=127.0.0.1
# NODE_ENV=production

# Upload + rate limits
MD_MAX_BYTES=26214400          # 25 MB
MD_RATE_MAX=30                 # conversions per window, per IP
MD_RATE_WINDOW_MS=3600000      # 1 hour

# markitdown (Python). Install with: pipx install markitdown[all]
# If the binary isn't on PATH, set the full path here.
MARKITDOWN_CMD=markitdown
# MARKITDOWN_DISABLED=1        # set to force Node-only mode
MARKITDOWN_TIMEOUT_MS=60000

# Console summary token (must match SNIPPETS-style token in console .env)
# node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
SUMMARY_TOKEN=
